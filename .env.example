# ── FabricBazaar Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — add it to .gitignore

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string-minimum-32-chars

# ── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite — fine for local only):
# DATABASE_URL=   (leave blank, SQLite auto-used)
#
# Production (PostgreSQL — REQUIRED for deployment):
# DATABASE_URL=postgresql://user:password@host:5432/fabricbazaar
DATABASE_URL=

# ── Razorpay ─────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.razorpay.com → Settings → API Keys
# Use TEST keys (rzp_test_...) for development — no real money moves.
# Use LIVE keys (rzp_live_...) for production.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Your Razorpay UPI payment handle (for the direct UPI button)
# e.g. if your link is razorpay.me/@yourhandle then set:
RAZORPAY_UPI_ID=yourhandle
