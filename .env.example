# ── FabricBazaar Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# Never commit .env to git.

# Flask
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string

# ── Razorpay ─────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.razorpay.com → Settings → API Keys
#
# Use TEST keys (rzp_test_...) for development — no real money moves.
# Use LIVE keys (rzp_live_...) for production.
#
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Your Razorpay UPI payment link handle (for the direct UPI button)
# e.g. if your link is razorpay.me/@yourname then set:
RAZORPAY_UPI_ID=shivamsurajdube
